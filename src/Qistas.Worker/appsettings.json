{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/qistas-worker-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "Qistas": {
    "ActiveEnvironment": "Dev",
    "Tenant": "AlsahlGroup.com",
    "Environments": {
      "Dev": {
        "BaseUrl": "https://btodevbox12461bf30703598f3devaos.axcloud.dynamics.com/",
        "CompanyId": "Bell",
        "ClientId": "",
        "ClientSecretProtected": ""
      },
      "Test": {
        "BaseUrl": "https://alsahl-test.sandbox.operations.eu.dynamics.com/",
        "CompanyId": "Bell",
        "ClientId": "",
        "ClientSecretProtected": ""
      },
      "Prod": {
        "BaseUrl": "https://alsahl.operations.eu.dynamics.com/",
        "CompanyId": "Bell",
        "ClientId": "",
        "ClientSecretProtected": ""
      }
    },
    "Retry": {
      "MaxAttempts": 3,
      "BaseDelaySeconds": 2,
      "TimeoutSeconds": 15,
      "CircuitBreakerFailureRatio": 0.5,
      "CircuitBreakerSamplingDurationSeconds": 30,
      "CircuitBreakerMinimumThroughput": 5,
      "CircuitBreakerBreakDurationSeconds": 30
    },
    "Outbox": {
      "SqlitePath": "qistas-outbox.db",
      "BatchSize": 25,
      "PollIntervalSeconds": 30
    }
  }
}
